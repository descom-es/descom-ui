{
  "name": "descom-ui",
  "version": "0.5.2",
  "description": "Common Vue.js components we use at Descom.es",
  "repository": {
    "type": "git",
    "url": "https://github.com/descom-es/descom-ui"
  },
  "bugs": {
    "url": "https://github.com/descom-es/descom-ui/issues"
  },
  "contributors": [
    {
      "name": "Víctor García",
      "email": "victorgf2011@gmail.com",
      "url": "https://tortitas.eu"
    },
    {
      "name": "César García"
    }
  ],
  "keywords": [
    "vue",
    "vuejs",
    "components",
    "ui",
    "descom"
  ],
  "license": "MIT",
  "main": "dist/descom-ui.umd.js",
  "module": "dist/descom-ui.mjs",
  "unpkg": "dist/descom-ui.umd.js",
  "exports": {
    ".": {
      "import": "./dist/descom-ui.mjs",
      "require": "./dist/descom-ui.umd.js"
    },
    "./dist/descom-ui.css": "./dist/descom-ui.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/*",
    "src/**/*.vue"
  ],
  "sideEffects": [
    "*.css",
    "*.scss",
    "*.vue"
  ],
  "scripts": {
    "serve": "vite",
    "build": "vite build"
  },
  "dependencies": {},
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "sass": "^1.83.0",
    "vite": "^6.0.5",
    "vue": "^3.5.13"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "engines": {
    "node": ">=18"
  }
}
